# Core
LLM_PROVIDER=codex
LLM_MODEL=gpt-5.4-mini
TARGET_URL=https://example.com
MANUAL_LIST_DIR=manual-list
OUTPUT_DIR=run-artifacts

# Optional direct artifacts (if not using browser capture)
# HTML_FILE=/absolute/path/page.html
# QUESTION_IDS=question_1,question_4
# CAPTURE_BROWSER=false

# Playwright capture
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_WAIT_UNTIL=networkidle
NAVIGATION_TIMEOUT_MS=45000
POST_LOAD_WAIT_MS=1200
VIEWPORT_SETTLE_MS=500
DEFAULT_VIEWPORTS_JSON=[{"name":"desktop","width":1366,"height":768}]
QUESTION_VIEWPORTS_JSON={"question_9":[{"name":"mobile","width":320,"height":900},{"name":"tablet","width":768,"height":1024},{"name":"desktop","width":1366,"height":900}],"question_16":[{"name":"mobile","width":390,"height":844},{"name":"desktop","width":1366,"height":900}]}
SCREENSHOT_QUESTION_IDS=question_1,question_3,question_4,question_5,question_8,question_9,question_10,question_12,question_14,question_15,question_16

# Provider keys/endpoints
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

LLAMA_API_KEY=
LLAMA_BASE_URL=http://localhost:8000/v1

OLLAMA_BASE_URL=http://localhost:11434

# Publish final report to API
PUBLISH_API_URL=
PUBLISH_API_TOKEN=
PUBLISH_TIMEOUT_SECONDS=30

# Upload Playwright trace to S3 path-style URL
S3_UPLOAD_ENABLED=false
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET=
S3_KEY_PREFIX=playwright-traces
S3_UPLOAD_METHOD=POST
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
